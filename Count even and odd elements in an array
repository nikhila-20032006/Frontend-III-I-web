package array;

public class CountEvenorObb {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int []arr= {1,2,3,4,5,6};
		int count=0;
		int count1=0;
		for(int i=0;i<arr.length;i++) {
			if(arr[i]%2==0) {
				count++;
			}
			else{
				count1++;
			}
		}
		System.out.println("Even elements:"+count);
System.out.println("Odd elements:"+count1);
	}

}
