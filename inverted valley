package pattern;


public class P8 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub

		int n=4;
		for(int i=1;i<=n;i++) {
			for(int j=i;j<=n;j++) {
				System.out.print("*");
			}
			for(int k=1;k<=i-1;k++) {
				System.out.print(" ");
			}
			for(int k=1;k<=i-1;k++) {
				System.out.print(" ");
			}
			for(int m=0;m<=n-i;m++) {
				System.out.print("*");
			}
			System.out.println();
		}
			
	}

}

